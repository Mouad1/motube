# ─── Claude (Script generation) ─────────────────────────────────────────────
# Obtenir sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Gemini (Translation multilingue) ────────────────────────────────────────
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── ElevenLabs (TTS + Voice cloning) ────────────────────────────────────────
# Free tier : 10 000 chars/mois
# Obtenir sur : https://elevenlabs.io/app/settings
ELEVENLABS_API_KEY=...

# ─── YouTube / Google OAuth ──────────────────────────────────────────────────
# 1. Aller sur https://console.cloud.google.com/
# 2. Activer : YouTube Data API v3 + YouTube Analytics API
# 3. Créer des credentials OAuth 2.0 (type Web Application)
# 4. Ajouter comme URI de redirection autorisée :
#    http://localhost:3000/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
# Installer Redis localement : brew install redis && brew services start redis
# Ou utiliser Upstash (gratuit) : https://upstash.com/
REDIS_URL=redis://localhost:6379

# ─── Database ────────────────────────────────────────────────────────────────
# Chemin vers la base SQLite (créée automatiquement au démarrage)
DB_PATH=./data/motube.db
